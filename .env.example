# Public canonical site URL used for SEO metadata, sitemap, and robots.
NEXT_PUBLIC_SITE_URL=https://inner-glow.gr

# Secret Brevo API key. Set in .env.local and Vercel only. Do not commit a real key.
# Used by newsletter subscribe and both contact forms.
BREVO_API_KEY=

# Brevo contacts list id for website subscribers.
BREVO_LIST_ID=6

# Contact form recipient. Both forms send email to this address.
CONTACT_TO_EMAIL=info@inner-glow.gr

# Verified Brevo sender used for transactional emails.
# This must be verified in Brevo before emails can be sent.
BREVO_SENDER_EMAIL=info@inner-glow.gr
BREVO_SENDER_NAME=Inner Glow
